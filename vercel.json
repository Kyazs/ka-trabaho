{
  "version": 2,
  "functions": {
    "api/recommendation.ts": {
      "includeFiles": "src/data/**"
    },
    "api/chat.ts": {
      "includeFiles": "src/data/**"
    },
    "api/job-recommendation.ts": {
      "includeFiles": "src/data/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}